# DATABASE (match docker-compose exactly)
DB_NAME=surehealth
DB_USERNAME=surehealth
DB_PASSWORD=surehealth
DB_URL=jdbc:postgresql://postgres:5432/surehealth

# KAFKA
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# REDIS
REDIS_HOST=surehealth-redis
REDIS_PORT=6379

# JWT
JWT_SECRET=surehealth-super-secure-secret-key-min-32-
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# FILE
FILE_UPLOAD_DIR=uploads/

# SPRING
SPRING_PROFILES_ACTIVE=dev