<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-init" author="surehealth">
        <sqlFile path="db/changelog/001-init.sql" relativeToChangelogFile="false"/>
        <rollback>
            <sqlFile path="db/changelog/001-init-rollback.sql" relativeToChangelogFile="false"/>
        </rollback>
    </changeSet>

    <changeSet id="002-add-outbox" author="surehealth">
        <sqlFile path="db/changelog/002-outbox.sql" relativeToChangelogFile="false"/>
        <rollback>
            <sqlFile path="db/changelog/002-outbox-rollback.sql" relativeToChangelogFile="false"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
